const inputData = "3 4 7 7";

function solveVectorLength(coordinatesString) {
    const [x1, y1, x2, y2] = coordinatesString.trim().split(/\s+/).map(Number);

    const dx = x2 - x1;
    const dy = y2 - y1;

    const length = Math.sqrt(dx * dx + dy * dy);

    return length.toFixed(6);
}

const result = solveVectorLength(inputData);
console.log(result);

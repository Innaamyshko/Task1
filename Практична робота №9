const inputData = "45 51";

function solveBossSteps(inputString) {
    const [x, y] = inputString.trim().split(/\s+/).map(Number);
    const dist = y - x;

    if (dist === 0) return 0;

    const k = Math.floor(Math.sqrt(dist));

    if (dist === k * k) {
        return 2 * k - 1;
    } else if (dist <= k * k + k) {
        return 2 * k;
    } else {
        return 2 * k + 1;
    }
}

const result = solveBossSteps(inputData);
console.log(result);
